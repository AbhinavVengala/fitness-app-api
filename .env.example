# ===========================================
# Fitness Tracker API - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!

# ---- Spring Profile (dev or prod) ----
SPRING_PROFILES_ACTIVE=dev

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/fitness
MONGODB_DATABASE=fitness

# ---- JWT ----
# Generate a secure 256-bit key: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-needs-to-be-at-least-256-bits-long-for-hs256
JWT_EXPIRATION=86400000

# ---- Server ----
PORT=8080

# ---- Razorpay ----
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX

# ---- Email (Gmail SMTP) ----
# Use an App Password: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ---- App Config ----
APP_FRONTEND_URL=http://localhost:5173

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
